qa/**/*.js
qa/**/*.js.map

# TypeScript compilation artifacts (compiled .js next to .ts source)
# Build outputs are not committed; only .ts source is tracked.
src/debug/*.js
src/runtime/*.js
src/settings/*.js
src/sync/*.js
src/utils/*.js
src/*.js
tests/*.js

