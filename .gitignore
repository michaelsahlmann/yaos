# npm / bun
node_modules
bun.lock
server/bun.lock

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# telemetry.js is the Observer bundle, emitted by esbuild alongside main.js.
# It is a generated release artifact — not tracked source.
telemetry.js

# lab.js is the legacy name for the telemetry bundle (now telemetry.js).
# It must never reappear. If it does, esbuild.config.mjs has regressed.
lab.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

